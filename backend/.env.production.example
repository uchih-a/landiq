# Production Environment Variables
# Copy this file to .env.production and fill out all values before deploying

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (Render PostgreSQL)
# ═══════════════════════════════════════════════════════════════════════════
# Format: postgresql+asyncpg://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://landiq_user:YOUR_SECURE_PASSWORD@your-render-db.onrender.com:5432/landiq_db

# ═══════════════════════════════════════════════════════════════════════════
# JWT & SECURITY
# ═══════════════════════════════════════════════════════════════════════════
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-64-character-hex-string-minimum-32-characters-required
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# ═══════════════════════════════════════════════════════════════════════════
# CORS & ALLOWED ORIGINS
# ═══════════════════════════════════════════════════════════════════════════
# Comma-separated or JSON array - include your Vercel frontend URL
ALLOWED_ORIGINS=["https://landiq-kenya.vercel.app"]

# ═══════════════════════════════════════════════════════════════════════════
# MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
MODEL_DIR=./ml_models

# ═══════════════════════════════════════════════════════════════════════════
# GEOLOCATION & API
# ═══════════════════════════════════════════════════════════════════════════
NOMINATIM_USER_AGENT=landiq-kenya/1.0

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════════════════
APP_ENV=production
DEBUG=false
APP_VERSION=1.0.0
